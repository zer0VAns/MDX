@using Microsoft.AspNetCore.Components.Routing
@using mdxEcommerce.Client.Services
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JS
@inject AuthService AuthService
@implements IDisposable
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<header class="navbar @(scrolled ? "navbar--scrolled" : "") @(menuOpen ? "navbar--open" : "")">
    <div class="navbar-inner">

        <!-- Brand -->
        <a href="/" class="navbar-brand">MDX</a>

        <!-- Links (desktop) -->
        <nav class="navbar-links">
            <NavLink href="/" Match="NavLinkMatch.All">Home</NavLink>
            <NavLink href="/catalog">Catalog</NavLink>
            <NavLink href="/contact">Contact</NavLink>
        </nav>

        <!-- Actions -->
        <div class="navbar-actions">

            <!-- Account: cambia según estado de sesión -->
            @if (isAuthenticated)
            {
                <div class="account-wrap">
                    <button class="icon-link icon-btn" title="@username" @onclick="ToggleAccountMenu">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="1.4"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                    </button>

                    @if (accountMenuOpen)
                    {
                        <div class="account-dropdown">
                            <div class="account-dropdown-user">@username</div>
                            @if (role == "Admin")
                            {
                                <a href="/admin" class="account-dropdown-item" @onclick="CloseAccountMenu">Admin</a>
                            }
                            <button class="account-dropdown-item account-dropdown-item--danger"
                                    @onclick="HandleLogout">
                                Sign Out
                            </button>
                        </div>
                    }
                </div>
            }
            else
            {
                <a href="/login" class="icon-link" title="Sign In">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.4"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </a>
            }

            <!-- Cart -->
            <a href="/" class="icon-link cart-link" title="Cart">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.4"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                    <line x1="3" y1="6" x2="21" y2="6" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
                <span class="cart-badge">0</span>
            </a>

        </div>
    </div>
</header>

@code {
    private bool scrolled         = false;
    private bool menuOpen         = false;
    private bool accountMenuOpen  = false;
    private bool isAuthenticated  = false;
    private string? username;
    private string? role;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await LoadAuthStateAsync();
    }

    private async Task LoadAuthStateAsync()
    {
        isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (isAuthenticated)
        {
            username = await AuthService.GetUsernameAsync();
            role     = await AuthService.GetRoleAsync();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        menuOpen        = false;
        accountMenuOpen = false;
        // Recargar estado de auth al navegar (ej: después de login/logout)
        _ = InvokeAsync(async () =>
        {
            await LoadAuthStateAsync();
            StateHasChanged();
        });
    }

    private void ToggleAccountMenu()
    {
        accountMenuOpen = !accountMenuOpen;
        StateHasChanged();
    }

    private void CloseAccountMenu()
    {
        accountMenuOpen = false;
        StateHasChanged();
    }

    private void ToggleMenu()
    {
        menuOpen = !menuOpen;
        StateHasChanged();
    }

    private async Task HandleLogout()
    {
        accountMenuOpen = false;
        await AuthService.LogoutAsync();
        isAuthenticated = false;
        username        = null;
        role            = null;
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
