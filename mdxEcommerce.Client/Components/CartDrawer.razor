@using mdxEcommerce.Client.Models
@using mdxEcommerce.Client.Services
@inject CartService CartService
@implements IDisposable
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject Microsoft.JSInterop.IJSRuntime JS

@if (CartService.IsOpen)
{
    <div class="drawer-overlay" @onclick="CartService.CloseCart"></div>
}

<div class="cart-drawer @(CartService.IsOpen ? "cart-drawer--open" : "")">
    <div class="drawer-header">
        <h2 class="drawer-title">Your Cart</h2>
        <button class="drawer-close" @onclick="CartService.CloseCart" aria-label="Close cart">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.4"
                 stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>

    <div class="drawer-body">
        @if (!CartService.Items.Any())
        {
            <div class="drawer-empty">
                <p class="drawer-empty-text">Your cart is empty.</p>
                <a href="/catalog" class="btn-ghost-sm" @onclick="CartService.CloseCart">Explore Collection →</a>
            </div>
        }
        else
        {
            <ul class="cart-list">
                @foreach (var item in CartService.Items)
                {
                    <li class="cart-item">
                        <div class="cart-item-image-wrap">
                            <img src="@item.ImageUrl" alt="@item.Name" class="cart-item-image" />
                        </div>
                        <div class="cart-item-info">
                            <span class="cart-item-name">@item.Name</span>
                            <span class="cart-item-price">@item.Price.ToString("C")</span>
                            <div class="cart-item-qty">
                                <button class="qty-btn" @onclick="() => Decrement(item)">−</button>
                                <span class="qty-value">@item.Quantity</span>
                                <button class="qty-btn" @onclick="() => Increment(item)">+</button>
                            </div>
                        </div>
                        <button class="cart-item-remove" @onclick="() => Remove(item)" aria-label="Remove">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.4"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="6" x2="6" y2="18"/>
                                <line x1="6" y1="6" x2="18" y2="18"/>
                            </svg>
                        </button>
                    </li>
                }
            </ul>
        }
    </div>

    @if (CartService.Items.Any())
    {
        <div class="drawer-footer">
            <div class="drawer-total">
                <span class="drawer-total-label">Total</span>
                <span class="drawer-total-value">@CartService.TotalPrice.ToString("C")</span>
            </div>
            <button class="btn-checkout" @onclick="HandleCheckout">Checkout</button>
            <button class="btn-clear" @onclick="Clear">Clear Cart</button>
        </div>
    }
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CartService.OnCartChanged += Refresh;
            await CartService.LoadAsync();
        }
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleCheckout()
{
    CartService.CloseCart();
    await JS.InvokeVoidAsync("alert", "¡Compra exitosa!");
    await CartService.ClearAsync();
}

    private async Task Increment(CartItem item) => await CartService.SetQuantityAsync(item.Id, item.Quantity + 1);
    private async Task Decrement(CartItem item) => await CartService.SetQuantityAsync(item.Id, item.Quantity - 1);
    private async Task Remove(CartItem item)    => await CartService.RemoveAsync(item.Id);
    private async Task Clear()                  => await CartService.ClearAsync();

    public void Dispose()
    {
        CartService.OnCartChanged -= Refresh;
    }
}
