    <Import Project="$(NuGetPackageRoot)microsoft.aspnetcore.components.webassembly.server\10.0.8\build\Microsoft.AspNetCore.Components.WebAssembly.Server.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.aspnetcore.components.webassembly.server\10.0.8\build\Microsoft.AspNetCore.Components.WebAssembly.Server.targets')" />
    <Import Project="$(NuGetPackageRoot)microsoft.aspnetcore.app.internal.assets\10.0.8\buildTransitive\Microsoft.AspNetCore.App.Internal.Assets.targets" Condition="Exists('$(NuGetPackageRoot)microsoft.aspnetcore.app.internal.assets\10.0.8\buildTransitive\Microsoft.AspNetCore.App.Internal.Assets.targets')" />
