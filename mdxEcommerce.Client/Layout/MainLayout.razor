@inherits LayoutComponentBase
@using mdxEcommerce.Client.Components
@using mdxEcommerce.Client.Layout

<div class="app-shell">
    <NavBar  />
    <main class="main-content">
        @Body
    </main>
    <CartDrawer />
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-top">
                <div class="footer-brand-col">
                    <a href="/" class="footer-brand">MDX</a>
                    <p class="footer-tagline">Premium minimalist objects,<br/>crafted with intention.</p>
                </div>
                <div class="footer-nav-cols">
                    <div class="footer-col">
                        <p class="footer-col-heading">Navigate</p>
                        <a href="/">Home</a>
                        <a href="/catalog">Catalog</a>
                        <a href="/contact">Contact</a>
                    </div>
                    <div class="footer-col">
                        <p class="footer-col-heading">Legal</p>
                        <a href="/">Privacy Policy</a>
                        <a href="/">Terms of Use</a>
                        <a href="/">Returns</a>
                    </div>
                    <div class="footer-col">
                        <p class="footer-col-heading">Follow</p>
                        <a href="/" target="_blank" rel="noopener">Instagram</a>
                        <a href="/" target="_blank" rel="noopener">Twitter</a>
                        <a href="/" target="_blank" rel="noopener">Pinterest</a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <span class="footer-copy">&copy; 2025 MDX — All rights reserved.</span>
                <span class="footer-made">Designed with precision.</span>
            </div>
        </div>
    </footer>
</div>